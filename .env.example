# Database
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/gymapp
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=gymapp

# Auth (Clerk)
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Mobile App
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Environment
NODE_ENV=development

# CORS (comma-separated list of allowed origins, optional)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting (optional, defaults shown)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# Error Tracking (optional)
# Get DSN from https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Pino logs forwarded to Sentry Logs. Defaults to "warn,error,fatal";
# widen to "info,warn,error,fatal" for full request-level logs.
# SENTRY_LOG_LEVELS=warn,error,fatal
