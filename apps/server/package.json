{
  "name": "@gymapp/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import=tsx --import=./src/instrument.ts --watch src/index.ts",
    "build": "tsc",
    "start": "node --import=./dist/instrument.js dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.5",
    "@gymapp/db": "workspace:*",
    "@gymapp/engine": "workspace:*",
    "@gymapp/types": "workspace:*",
    "@gymapp/validation": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-openapi": "^0.18.0",
    "@hono/zod-validator": "^0.4.0",
    "@sentry/node": "^10.52.0",
    "@sentry/profiling-node": "^10.52.0",
    "hono": "^4.6.0",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "dotenv": "^16.4.0",
    "eslint": "^9.39.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
