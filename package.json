{
  "name": "lifters-club",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "db:seed:programs": "turbo db:seed:programs",
    "db:seed:all": "turbo db:seed:all",
    "db:studio": "turbo db:studio",
    "mobile": "pnpm --filter @gymapp/mobile start",
    "mobile:ios": "pnpm --filter @gymapp/mobile ios",
    "mobile:android": "pnpm --filter @gymapp/mobile android"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
