{
  "name": "lifters-club",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@types/react": "19.0.0",
      "@types/react-dom": "19.0.0"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:db:reset": "pnpm test:db:down && pnpm test:db:up",
    "test:integration": "pnpm test:db:up && DATABASE_URL=postgres://test:test@localhost:5433/lifters_test pnpm db:push && pnpm test; pnpm test:db:down",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "db:seed:programs": "turbo db:seed:programs",
    "db:seed:all": "turbo db:seed:all",
    "db:studio": "turbo db:studio",
    "mobile": "pnpm --filter @gymapp/mobile start",
    "mobile:ios": "pnpm --filter @gymapp/mobile ios",
    "mobile:android": "pnpm --filter @gymapp/mobile android"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
